{
  "name": "ui-replay-runner",
  "version": "0.1.0",
  "description": "Project-agnostic Playwright runner that turns YAML scenarios into traced runs (screenshots + trace.zip + WebM) plus an offline replay.html report. Extracted from the autogo dashboard autotest harness.",
  "type": "module",
  "bin": {
    "ui-replay": "./bin/ui-replay.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "scenarios/example.yaml",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "init": "node bin/ui-replay.mjs init",
    "run": "node bin/ui-replay.mjs run",
    "report": "node bin/ui-replay.mjs report",
    "prune": "node bin/ui-replay.mjs prune",
    "example": "node bin/ui-replay.mjs run scenarios/example.yaml"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "yaml": "^2.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
